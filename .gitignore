# Python 데이터 분석 프로젝트용 .gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
*.egg-info/
.dist-info/
build/
develop-eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environment
.venv/
env/
venv/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VS Code settings
.vscode/

# PyCharm project files
.idea/

# Test logs and caches
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
*.log

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Data files (large datasets) - adjust pattern as needed
# data/

# OS generated files
.DS_Store
Thumbs.db

# End of .gitignore
